# ===== 服务器配置 =====
PORT=3000
NODE_ENV=development

# ===== 数据库配置 =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_storyboard
DB_USER=root
DB_PASSWORD=your_password_here

# ===== JWT 配置 =====
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d

# ===== Bcrypt =====
BCRYPT_ROUNDS=12
